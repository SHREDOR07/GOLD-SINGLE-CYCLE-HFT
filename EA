#property version   "1.50"
#property strict

#include <Trade\Trade.mqh>

//--- INPUT PARAMETERS
input double   InpLots          = 0.01;      // Lot size
input int      InpGridStep      = 50;        // Distance for pending orders (Points) - CHANGED TO 50
input double   InpTargetUSD     = 2.00;      // Take Profit in USD
input double   InpStopLossUSD   = 1.00;      // Stop Loss in USD
input double   InpBreakEvenUSD  = 1.00;      // Profit in USD to trigger Break Even
input long     InpMagicNumber   = 123456;    // Magic Number

//--- GLOBALS
CTrade trade;

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   int posCount = CountPositions();

   // 1. If a trade is active, manage Break Even and clear pending orders
   if(posCount > 0)
   {
      DeleteAllPendingOrders();
      CheckBreakEven();
      return; 
   }

   // 2. If no position and no pending orders, place the grid
   if(CountPendingOrders() == 0)
   {
      PlaceGridWithTargets();
   }
}

//+------------------------------------------------------------------+
//| Calculate Price Distance for a specific USD amount               |
//+------------------------------------------------------------------+
double GetPriceDistByUSD(double usdAmount)
{
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   
   if(tickValue == 0) return 0;
   
   // Formula: Distance = (USD / (Lots * TickValue)) * TickSize
   return (usdAmount / (InpLots * tickValue)) * tickSize;
}

//+------------------------------------------------------------------+
//| Place Grid with Hard SL and TP based on USD                      |
//+------------------------------------------------------------------+
void PlaceGridWithTargets()
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Calculate the price distances required for $1 loss and $2 profit
   double slDistance = GetPriceDistByUSD(InpStopLossUSD);
   double tpDistance = GetPriceDistByUSD(InpTargetUSD);
   
   if(slDistance == 0 || tpDistance == 0) return;

   //--- BUY STOP SETUP (50 points above Ask)
   double buyStopPrice = NormalizeDouble(ask + InpGridStep * _Point, _Digits);
   double buySL        = NormalizeDouble(buyStopPrice - slDistance, _Digits);
   double buyTP        = NormalizeDouble(buyStopPrice + tpDistance, _Digits);
   
   trade.BuyStop(InpLots, buyStopPrice, _Symbol, buySL, buyTP);

   //--- SELL STOP SETUP (50 points below Bid)
   double sellStopPrice = NormalizeDouble(bid - InpGridStep * _Point, _Digits);
   double sellSL         = NormalizeDouble(sellStopPrice + slDistance, _Digits);
   double sellTP         = NormalizeDouble(sellStopPrice - tpDistance, _Digits);

   trade.SellStop(InpLots, sellStopPrice, _Symbol, sellSL, sellTP);
   
   Print("Pending orders placed 50 points from price with SL/TP attached.");
}

//+------------------------------------------------------------------+
//| Move Stop Loss to Entry when $1.00 profit is reached             |
//+------------------------------------------------------------------+
void CheckBreakEven()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(PositionSelectByTicket(ticket))
      {
         if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
         
         // Calculate net profit including commissions and swap
         double profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP) + PositionGetDouble(POSITION_COMMISSION);
         double entry  = PositionGetDouble(POSITION_PRICE_OPEN);
         double currentSL = PositionGetDouble(POSITION_SL);
         
         if(profit >= InpBreakEvenUSD)
         {
            // Buy Position: Move SL to Entry
            if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY && currentSL < entry)
            {
               trade.PositionModify(ticket, entry, PositionGetDouble(POSITION_TP));
               Print("Break Even: $1 profit reached, SL moved to entry.");
            }
            // Sell Position: Move SL to Entry
            if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_SELL && (currentSL > entry || currentSL == 0))
            {
               trade.PositionModify(ticket, entry, PositionGetDouble(POSITION_TP));
               Print("Break Even: $1 profit reached, SL moved to entry.");
            }
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Helper Functions                                                 |
//+------------------------------------------------------------------+
int CountPositions()
{
   int count = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionSelectByTicket(PositionGetTicket(i)))
         if(PositionGetInteger(POSITION_MAGIC) == InpMagicNumber) count++;
   }
   return count;
}

int CountPendingOrders()
{
   int count = 0;
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(OrderSelect(OrderGetTicket(i)))
         if(OrderGetInteger(ORDER_MAGIC) == InpMagicNumber) count++;
   }
   return count;
}

void DeleteAllPendingOrders()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(OrderSelect(ticket))
         if(OrderGetInteger(ORDER_MAGIC) == InpMagicNumber)
            trade.OrderDelete(ticket);
   }
}
