#include <Trade\Trade.mqh>

//--- INPUT PARAMETERS
input double   InpLots          = 0.01;      // Lot size
input int      InpGridStep      = 100;       // Distance for pending orders (Points)
input double   InpTargetUSD     = 2.00;      // Take Profit in USD
input double   InpStopLossUSD   = 1.00;      // Stop Loss in USD
input double   InpBreakEvenUSD  = 1.00;      // Profit in USD to trigger Break Even
input long     InpMagicNumber   = 123456;    // Magic Number

//--- GLOBALS
CTrade trade;

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   int posCount = CountPositions();

   // 1. If a trade is active
   if(posCount > 0)
   {
      // Ensure the "other" pending order is removed immediately
      DeleteAllPendingOrders(); 
      
      // Manage the active position (Slippage Correction + Break Even)
      ManageActiveTrade();
      return; 
   }

   // 2. If no position and no pending orders, place the grid at 100 points
   if(CountPendingOrders() == 0)
   {
      PlaceGridWithTargets();
   }
}

//+------------------------------------------------------------------+
//| Convert USD amount to Price distance                             |
//+------------------------------------------------------------------+
double GetPriceDistByUSD(double usdAmount)
{
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickValue <= 0) return 0;
   // Points = (USD / (Lots * TickValue)) * TickSize
   return (usdAmount / (InpLots * tickValue)) * tickSize;
}

//+------------------------------------------------------------------+
//| Combined Slippage Rectification and Break Even Logic             |
//+------------------------------------------------------------------+
void ManageActiveTrade()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(PositionSelectByTicket(ticket))
      {
         if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
         
         double openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
         double currentSL = PositionGetDouble(POSITION_SL);
         double currentTP = PositionGetDouble(POSITION_TP);
         double netProfit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP) + PositionGetDouble(POSITION_COMMISSION);
         
         double slDist = GetPriceDistByUSD(InpStopLossUSD);
         double tpDist = GetPriceDistByUSD(InpTargetUSD);
         
         ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);

         // --- STEP 1: BREAK EVEN LOGIC ($1.00 profit) ---
         if(netProfit >= InpBreakEvenUSD)
         {
            // If Buy and SL not yet at entry
            if(type == POSITION_TYPE_BUY && currentSL < openPrice)
            {
               trade.PositionModify(ticket, openPrice, currentTP);
               Print("Break Even: Profit reached $1.00. SL moved to entry.");
               return; 
            }
            // If Sell and SL not yet at entry
            if(type == POSITION_TYPE_SELL && (currentSL > openPrice || currentSL == 0))
            {
               trade.PositionModify(ticket, openPrice, currentTP);
               Print("Break Even: Profit reached $1.00. SL moved to entry.");
               return;
            }
         }

         // --- STEP 2: SLIPPAGE RECTIFICATION ---
         // Only rectify if we haven't moved to Break Even yet
         bool isAtBreakEven = (MathAbs(currentSL - openPrice) < _Point);
         
         if(!isAtBreakEven)
         {
            double idealSL = (type == POSITION_TYPE_BUY) ? (openPrice - slDist) : (openPrice + slDist);
            double idealTP = (type == POSITION_TYPE_BUY) ? (openPrice + tpDist) : (openPrice - tpDist);
            
            // If current SL deviates from ideal SL by more than half a point, rectify
            if(MathAbs(currentSL - idealSL) > _Point * 0.5)
            {
               trade.PositionModify(ticket, NormalizeDouble(idealSL, _Digits), NormalizeDouble(idealTP, _Digits));
               Print("Slippage Rectified: SL/TP adjusted to exact USD distance from actual entry.");
            }
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Place initial Pending Orders at 100 points distance              |
//+------------------------------------------------------------------+
void PlaceGridWithTargets()
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   double slDist = GetPriceDistByUSD(InpStopLossUSD);
   double tpDist = GetPriceDistByUSD(InpTargetUSD);
   
   if(slDist <= 0 || tpDist <= 0) return;

   // Buy Stop: 100 points above Ask
   double buyPrice = NormalizeDouble(ask + InpGridStep * _Point, _Digits);
   double buySL    = NormalizeDouble(buyPrice - slDist, _Digits);
   double buyTP    = NormalizeDouble(buyPrice + tpDist, _Digits);
   trade.BuyStop(InpLots, buyPrice, _Symbol, buySL, buyTP);

   // Sell Stop: 100 points below Bid
   double sellPrice = NormalizeDouble(bid - InpGridStep * _Point, _Digits);
   double sellSL     = NormalizeDouble(sellPrice + slDist, _Digits);
   double sellTP     = NormalizeDouble(sellPrice - tpDist, _Digits);
   trade.SellStop(InpLots, sellPrice, _Symbol, sellSL, sellTP);
   
   Print("Pending Orders placed 100 points from market.");
}

//+------------------------------------------------------------------+
//| Helper Functions                                                 |
//+------------------------------------------------------------------+
int CountPositions() {
   int c = 0;
   for(int i = PositionsTotal()-1; i >= 0; i--)
      if(PositionSelectByTicket(PositionGetTicket(i)))
         if(PositionGetInteger(POSITION_MAGIC) == InpMagicNumber) c++;
   return c;
}

int CountPendingOrders() {
   int c = 0;
   for(int i = OrdersTotal()-1; i >= 0; i--)
      if(OrderSelect(OrderGetTicket(i)))
         if(OrderGetInteger(ORDER_MAGIC) == InpMagicNumber) c++;
   return c;
}

void DeleteAllPendingOrders() {
   for(int i = OrdersTotal()-1; i >= 0; i--) {
      ulong t = OrderGetTicket(i);
      if(OrderSelect(t) && OrderGetInteger(ORDER_MAGIC) == InpMagicNumber)
         trade.OrderDelete(t);
   }
}
